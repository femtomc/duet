"""
Duet Workflow Definition.

This file defines the orchestration workflow for your project using Duet's
Python DSL. Customize agents, channels, phases, and transitions to fit your
development process.

Documentation: See docs/workflow_dsl.md for detailed DSL reference.
"""

from duet.dsl import Agent, Channel, Phase, Transition, When, Workflow

# ──────────────────────────────────────────────────────────────────────────────
# Workflow Definition
# ──────────────────────────────────────────────────────────────────────────────

workflow = Workflow(
    # ──── Agents ────
    # Define the AI agents that execute phases.
    # Each agent maps to a provider (codex, claude) with a specific model.
    agents=[
        Agent(
            name="planner",
            provider="codex",
            model="gpt-5-codex",
            # timeout=300,  # Optional: uncomment to set timeout in seconds
        ),
        Agent(
            name="implementer",
            provider="claude",
            model="sonnet",
            # timeout=600,  # Optional: uncomment to set timeout in seconds
        ),
        Agent(
            name="reviewer",
            provider="codex",
            model="gpt-5-codex",
        ),
    ],

    # ──── Channels ────
    # Define communication channels for message passing between phases.
    # Channels carry structured data (text, JSON, verdicts, git diffs, etc.).
    channels=[
        Channel(
            name="task",
            description="Input task specification from user",
            schema="text",
        ),
        Channel(
            name="plan",
            description="Implementation plan drafted by planner",
            schema="text",
        ),
        Channel(
            name="code",
            description="Implementation artifacts and changes",
            schema="git_diff",
        ),
        Channel(
            name="verdict",
            description="Review outcome (approve/changes_requested/blocked)",
            schema="verdict",
        ),
        Channel(
            name="feedback",
            description="Review feedback for replanning",
            schema="text",
        ),
    ],

    # ──── Phases ────
    # Define workflow phases with channel dependencies.
    # Each phase consumes from input channels and publishes to output channels.
    phases=[
        Phase(
            name="plan",
            agent="planner",
            consumes=["task", "feedback"],  # Reads task and optional feedback
            publishes=["plan"],             # Writes implementation plan
            description="Draft implementation plan based on task specification",
        ),
        Phase(
            name="implement",
            agent="implementer",
            consumes=["plan"],              # Reads the plan
            publishes=["code"],             # Writes code changes
            description="Execute the plan and make repository changes",
        ),
        Phase(
            name="review",
            agent="reviewer",
            consumes=["plan", "code"],      # Reads plan + implementation
            publishes=["verdict", "feedback"],  # Writes verdict + optional feedback
            description="Review implementation against plan requirements",
        ),
        Phase(
            name="done",
            agent="reviewer",
            description="Workflow completed successfully",
            is_terminal=True,
        ),
        Phase(
            name="blocked",
            agent="reviewer",
            description="Workflow blocked, requires human intervention",
            is_terminal=True,
        ),
    ],

    # ──── Transitions ────
    # Define state transitions with guard conditions.
    # Guards evaluate channel values to determine which transition fires.
    transitions=[
        # PLAN → IMPLEMENT (always, if plan generated)
        Transition(
            from_phase="plan",
            to_phase="implement",
            when=When.always(),
        ),

        # IMPLEMENT → REVIEW (always, if code changes made)
        Transition(
            from_phase="implement",
            to_phase="review",
            when=When.always(),
        ),

        # REVIEW → DONE (if approved)
        Transition(
            from_phase="review",
            to_phase="done",
            when=When.channel_has("verdict", "approve"),
            priority=10,  # Higher priority = evaluated first
        ),

        # REVIEW → PLAN (if changes requested)
        Transition(
            from_phase="review",
            to_phase="plan",
            when=When.channel_has("verdict", "changes_requested"),
            priority=5,
        ),

        # REVIEW → BLOCKED (if critical issues)
        Transition(
            from_phase="review",
            to_phase="blocked",
            when=When.channel_has("verdict", "blocked"),
            priority=15,  # Highest priority - check first
        ),
    ],

    # Initial phase (defaults to first phase if not specified)
    initial_phase="plan",
)

